# 이 파일을 복사해서 ".env" 로 저장한 뒤, 실제 발급받은 키 값으로 채워 넣으세요.
# .env 파일 자체는 절대 커밋/제출하지 마세요.

# OpenAI Platform (https://platform.openai.com/api-keys) 에서 발급
OPENAI_API_KEY=

# (선택) 사용할 OpenAI 모델. 기본값: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Naver 개발자 센터(https://developers.naver.com/apps) 에서
# "검색" API 사용 설정 후 발급되는 Client ID / Secret
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
